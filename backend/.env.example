# ============================================================
# HydroMonitor backend — переменные окружения.
# Скопируйте в .env и заполните перед первым запуском:
#   cp .env.example .env
# .env НЕ коммитится в git (см. .gitignore).
# ============================================================

ENV=development

# --- База данных ---
# Для хакатона/демо достаточно SQLite. Для прода — PostgreSQL (+PostGIS опционально):
# DATABASE_URL=postgresql+psycopg://hydromonitor:password@localhost:5432/hydromonitor
DATABASE_URL=sqlite:///./hydromonitor.db

# --- JWT ---
# ОБЯЗАТЕЛЬНО смените на случайную строку перед деплоем:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_INSECURE_DEFAULT_DO_NOT_USE_IN_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Администратор (создаётся автоматически при первом запуске) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@hydromonitor.local

# --- Демо-доступ только для чтения (для показа жюри) ---
CREATE_DEMO_VIEWER=true
DEMO_VIEWER_USERNAME=viewer
DEMO_VIEWER_PASSWORD=viewer12345

# --- CORS: домены фронтенда, через запятую ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- AI-агент (опционально) ---
# Рекомендуемый бесплатный вариант — Groq (без банковской карты):
#   1. Зарегистрируйтесь на https://console.groq.com и создайте API-ключ
#   2. AI_AGENT_ENABLED=true, AI_PROVIDER=groq, AI_PROVIDER_API_KEY=gsk_...
# Другие варианты: grok (платный, x.ai), openrouter (есть бесплатные модели
# с суффиксом :free), ollama (полностью локально, без ключа), anthropic
# (платный, Claude). Подробности — README → «AI-агент».
AI_AGENT_ENABLED=true
AI_PROVIDER=groq
AI_PROVIDER_API_KEY=
